{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "serverUrl": {
      "type": "string",
      "format": "uri",
      "description": "PractiTest MCP server URL."
    },
    "token": {
      "type": "string",
      "writeOnly": true,
      "description": "PractiTest personal API token. Used as Bearer token to authenticate with the PractiTest MCP server."
    }
  },
  "required": ["serverUrl", "token"],
  "additionalProperties": false
}
